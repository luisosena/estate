{
  "name": "estate-practice-mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-navigation/bottom-tabs": "^7.4.7",
    "@react-navigation/native": "^7.1.18",
    "@react-navigation/native-stack": "^7.3.26",
    "axios": "^1.12.2",
    "axios-retry": "^4.5.0",
    "expo": "~55.0.26",
    "expo-crypto": "~55.0.15",
    "expo-dev-client": "~55.0.35",
    "expo-device": "~55.0.17",
    "expo-document-picker": "~55.0.13",
    "expo-font": "~55.0.8",
    "expo-local-authentication": "~55.0.14",
    "expo-notifications": "^55.0.23",
    "expo-secure-store": "~55.0.14",
    "expo-status-bar": "~55.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-paper": "^5.14.5",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "@types/uuid": "^9.0.8",
    "babel-preset-expo": "~55.0.8",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.18",
    "metro-react-native-babel-preset": "^0.77.0",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": [
      "<rootDir>/src/__tests__/setup.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/android/",
      "/ios/",
      "/setup\\.ts$"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-navigation|expo|expo-.*|@expo/.*|@expo-google-fonts/.*|@testing-library/.*|@expo/vector-icons|react-native-paper|react-native-reanimated)/)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/"
    }
  }
}
