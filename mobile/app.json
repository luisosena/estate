{
  "expo": {
    "name": "Estate Practice",
    "slug": "estate-practice-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.estatepractice.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.estatepractice.app",
      "softwareKeyboardLayoutMode": "adjustResize"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store"
    ]
  }
}
