 utility status display.\n * @param status - Utility status: 'active', 'suspended', or 'disconnected'\n * @returns Hex color string for the given status\n */\nconst getUtilityStatusColor = (status: string): string => {\n  const statusColors: Record<string, string> = {\n    active: colors.status.active,\n    suspended: colors.status.pending,\n    disconnected: colors.status.overdue,\n  };\n  return statusColors[status] ?? colors.gray[400];\n};\n\nexport function TenantUtilitiesScreen() {\n  const navigation = useNavigation<NavigationProp>();\n  const [loading, setLoading] = useState(true);\n  const [refreshing, setRefreshing] = useState(false);\n  const [utilities, setUtilities] = useState<Utility[]>([]);\n\n  const fetchUtilities = async () => {\n    try {\n      const data = await tenantApi.getUtilities();\n      setUtilities(data.data);\n    } catch (error) {\n      console.error('Failed to fetch utilities:', error);\n    } finally {\n      setLoading(false);\n      setRefreshing(false);\n    }\n  };\n\n  useEffect(() => {\n    fetchUtilities();\n  }, []);\n\n  const onRefresh = () => {\n    setRefreshing(true);\n    fetchUtilities();\n  };\n\n  if (loading) return <LoadingScreen />;\n\n  return (\n    <ScrollView\n      style={screenStyles.container}\n      refreshControl={<RefreshControl refreshing={refreshing} onRefresh={onRefresh} />}\n    >\n      <View style={screenStyles.header}>\n        <Text variant=\"headlineSmall\" style={screenStyles.title}>Utilities</Text>\n        <Text variant=\"bodyMedium\" style={screenStyles.subtitle}>Track your utility connections</Text>\n      </View>\n\n      <Button\n        mode=\"contained\"\n        onPress={() => navigation.navigate('UtilityBills')}\n        style={{ marginHorizontal: 16, marginBottom: 16 }}\n        icon=\"file-document\"\n      >\n        View Utility Bills\n      </Button>\n\n      <Card style={screenStyles.card}>\n        <Card.Content>\n          {utilities?.length > 0 ? (\n            utilities.map((utility) => (\n              <View key={utility.id} style={screenStyles.listItem}>\n                <View>\n                  <Text variant=\"bodyMedium\" style={{ fontWeight: '500' }}>\n                    {capitalize(utility.utility_type?.name || 'Unknown')}\n                  </Text>\n                  <Text variant=\"bodySmall\" style={screenStyles.date}>\n                    Billing: {utility.billing_cycle}\n                  </Text>\n                  {utility.provider && (\n                    <Text variant=\"bodySmall\" style={screenStyles.date}>\n                      Provider: {utility.provider}\n                    </Text>\n                  )}\n                </View>\n                <View style={{ alignItems: 'flex-end' }}>\n                  <Text variant=\"bodyMedium\" style={{ fontWeight: 'bold' }}>\n                    {formatCurrency(utility.amount)}\n                  </Text>\n                  <Chip\n                    mode=\"flat\"\n                    compact\n                    style={[screenStyles.chip, { backgroundColor: getUtilityStatusColor(utility.status) + '20' }]}\n                  >\n                    {utility.status}\n                  </Chip>\n                </View>\n              </View>\n            ))\n          ) : (\n            <Text variant=\"bodyMedium\" style={screenStyles.empty}>No pending utilities</Text>\n          )}\n        </Card.Content>\n      </Card>\n    </ScrollView>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Admin\\Desktop\\SurveyCorps\\Projects\\estate-practice\\mobile\\src\\screens\\tenant\\UtilityBillsScreen.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'fetchBills'. Either include it or remove the dependency array.","line":54,"column":6,"nodeType":"ArrayExpression","endLine":54,"endColumn":14,"suggestions":[{"desc":"Update the dependencies array to be: [fetchBills, filter]","fix":{"range":[2126,2134],"text":"[fetchBills, filter]"}}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useCallback has a missing dependency: 'fetchBills'. Either include it or remove the dependency array.","line":60,"column":8,"nodeType":"ArrayExpression","endLine":60,"endColumn":10,"suggestions":[{"desc":"Update the dependencies array to be: [fetchBills]","fix":{"range":[2284,2286],"text":"[fetchBills]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useNavigation, useFocusEffect } from '@react-navigation/native';\nimport { NativeStackNavigationProp } from '@react-navigation/native-stack';\nimport React, { useEffect, useState, useCallback } from 'react';\nimport { View, ScrollView, RefreshControl, StyleSheet } from 'react-native';\nimport { Text, Card, Chip, Button } from 'react-native-paper';\n\nimport { tenantApi } from '../../api/tenant';\nimport { LoadingScreen } from '../../components/common/LoadingScreen';\nimport { colors } from '../../constants/colors';\nimport { screenStyles } from '../../constants/styles';\nimport type { TenantUtilitiesStackParamList, TenantPaymentsStackParamList } from '../../navigation/AppNavigator';\nimport type { UtilityBill, UtilityBillSummary } from '../../types';\nimport { formatCurrency, formatDate, capitalize } from '../../utils/formatters';\n\n// Combine navigation types for navigating between stacks\ntype NavigationProp = NativeStackNavigationProp<\n  TenantUtilitiesStackParamList & TenantPaymentsStackParamList\n>;\n\nconst getStatusColor = (status: string): string => {\n  const statusColors: Record<string, string> = {\n    paid: colors.status.paid,\n    partial: colors.status.pending,\n    overdue: colors.status.overdue,\n    pending: colors.status.pending,\n    waived: colors.gray[400],\n  };\n  return statusColors[status] ?? colors.gray[400];\n};\n\nexport function TenantUtilityBillsScreen() {\n  const navigation = useNavigation<NavigationProp>();\n  const [loading, setLoading] = useState(true);\n  const [refreshing, setRefreshing] = useState(false);\n  const [bills, setBills] = useState<UtilityBill[]>([]);\n  const [summary, setSummary] = useState<UtilityBillSummary | null>(null);\n  const [filter, setFilter] = useState<string | null>(null);\n\n  const fetchBills = async () => {\n    try {\n      const data = await tenantApi.getUtilityBills(filter || undefined);\n      setBills(data.data);\n      setSummary(data.summary);\n    } catch (error) {\n      console.error('Failed to fetch utility bills:', error);\n    } finally {\n      setLoading(false);\n      setRefreshing(false);\n    }\n  };\n\n  useEffect(() => {\n    fetchBills();\n  }, [filter]);\n\n  // Refresh bills when screen comes into focus (e.g., after making payment)\n  useFocusEffect(\n    useCallback(() => {\n      fetchBills();\n    }, []) // Empty deps - fetchBills already has filter in its scope\n  );\n\n  const onRefresh = () => {\n    setRefreshing(true);\n    fetchBills();\n  };\n\n  const handlePayBill = () => {\n    navigation.navigate('MakePayment', {\n      pendingAmount: summary?.total_outstanding || 0,\n    });\n  };\n\n  if (loading) return <LoadingScreen />;\n\n  return (\n    <ScrollView\n      style={screenStyles.container}\n      refreshControl={<RefreshControl refreshing={refreshing} onRefresh={onRefresh} />}\n    >\n      <View style={screenStyles.header}>\n        <Text variant=\"headlineSmall\" style={screenStyles.title}>Utility Bills</Text>\n        <Text variant=\"bodyMedium\" style={screenStyles.subtitle}>Track your utility payments</Text>\n      </View>\n\n      {/* Summary Card */}\n      {summary && (\n        <Card style={screenStyles.card}>\n          <Card.Content>\n            <Text variant=\"titleMedium\" style={screenStyles.title}>Summary</Text>\n            <View style={styles.summaryRow}>\n              <Text variant=\"bodyMedium\" style={screenStyles.date}>Total Due:</Text>\n              <Text variant=\"bodyMedium\" style={{ fontWeight: 'bold' }}>\n                {formatCurrency(summary.total_due)}\n              </Text>\n            </View>\n            <View style={styles.summaryRow}>\n              <Text variant=\"bodyMedium\" style={screenStyles.date}>Total Paid:</Text>\n              <Text variant=\"bodyMedium\" style={{ fontWeight: 'bold', color: colors.status.paid }}>\n                {formatCurrency(summary.total_paid)}\n              </Text>\n            </View>\n            <View style={styles.summaryRow}>\n              <Text variant=\"bodyMedium\" style={screenStyles.date}>Outstanding:</Text>\n              <Text variant=\"bodyMedium\" style={{ \n                fontWeight: 'bold', \n                color: summary.total_outstanding > 0 ? colors.status.overdue : colors.status.paid \n              }}>\n                {formatCurrency(summary.total_outstanding)}\n              </Text>\n            </View>\n            <View style={[styles.summaryRow, { borderTopWidth: 1, borderTopColor: colors.border, marginTop: 8, paddingTop: 8 }]}>\n              <Text variant=\"bodyMedium\" style={screenStyles.date}>Total Bills:</Text>\n              <Text variant=\"bodyMedium\" style={{ fontWeight: 'bold' }}>\n                {summary.bill_count}\n              </Text>\n            </View>\n            \n            {summary.total_outstanding > 0 && (\n              <Button\n                mode=\"contained\"\n                onPress={handlePayBill}\n                style={styles.payButton}\n                buttonColor={colors.status.overdue}\n              >\n                Pay Outstanding ({formatCurrency(summary.total_outstanding)})\n              </Button>\n            )}\n          </Card.Content>\n        </Card>\n      )}\n\n      {/* Filter Buttons */}\n      <View style={styles.filterContainer}>\n        <Button\n          mode={filter === null ? 'contained' : 'outlined'}\n          onPress={() => setFilter(null)}\n          style={styles.filterButton}\n          compact\n        >\n          All\n        </Button>\n        <Button\n          mode={filter === 'pending' ? 'contained' : 'outlined'}\n          onPress={() => setFilter('pending')}\n          style={styles.filterButton}\n          compact\n        >\n          Pending\n        </Button>\n        <Button\n          mode={filter === 'overdue' ? 'contained' : 'outlined'}\n          onPress={() => setFilter('overdue')}\n          style={styles.filterButton}\n          compact\n        >\n          Overdue\n        </Button>\n        <Button\n          mode={filter === 'paid' ? 'contained' : 'outlined'}\n          onPress={() => setFilter('paid')}\n          style={styles.filterButton}\n          compact\n        >\n          Paid\n        </Button>\n      </View>\n\n      {/* Bills List */}\n      <Card style={screenStyles.card}>\n        <Card.Content>\n          <Text variant=\"titleMedium\" style={screenStyles.title}>Bills</Text>\n          {bills.length > 0 ? (\n            bills.map((bill) => {\n              const utilityName = bill.tenancy_utility?.utility_type?.name || 'Unknown';\n              const outstanding = bill.amount_due - bill.amount_paid;\n              \n              return (\n                <View key={bill.id} style={styles.billItem}>\n                  <View style={styles.billHeader}>\n                    <View>\n                      <Text variant=\"bodyMedium\" style={{ fontWeight: '500' }}>\n                        {capitalize(utilityName)}\n                      </Text>\n                      <Text variant=\"bodySmall\" style={screenStyles.date}>\n                        Billing Month: {formatDate(bill.billing_month)}\n                      </Text>\n                    </View>\n                    <Chip\n                      mode=\"flat\"\n                      compact\n                      style={[styles.chip, { backgroundColor: getStatusColor(bill.status) + '20' }]}\n                      textStyle={{ color: getStatusColor(bill.status) }}\n                    >\n                      {bill.status}\n                    </Chip>\n                  </View>\n                  \n                  <View style={styles.billDetails}>\n                    <View style={styles.detailRow}>\n                      <Text variant=\"bodySmall\" style={screenStyles.date}>Amount Due:</Text>\n                      <Text variant=\"bodyMedium\" style={{ fontWeight: 'bold' }}>\n                        {formatCurrency(bill.amount_due)}\n                      </Text>\n                    </View>\n                    <View style={styles.detailRow}>\n                      <Text variant=\"bodySmall\" style={screenStyles.date}>Amount Paid:</Text>\n                      <Text variant=\"bodyMedium\" style={{ color: colors.status.paid }}>\n                        {formatCurrency(bill.amount_paid)}\n                      </Text>\n                    </View>\n                    <View style={styles.detailRow}>\n                      <Text variant=\"bodySmall\" style={screenStyles.date}>Outstanding:</Text>\n                      <Text variant=\"bodyMedium\" style={{ \n                        fontWeight: 'bold',\n                        color: outstanding > 0 ? colors.status.overdue : colors.status.paid \n                      }}>\n                        {formatCurrency(outstanding)}\n                      </Text>\n                    </View>\n                    <View style={styles.detailRow}>\n                      <Text variant=\"bodySmall\" style={screenStyles.date}>Due Date:</Text>\n                      <Text variant=\"bodyMedium\" style={{ \n                        color: bill.status === 'overdue' ? colors.status.overdue : colors.text.secondary \n                      }}>\n                        {formatDate(bill.due_date)}\n                      </Text>\n                    </View>\n                    {bill.units_consumed !== null && (\n                      <View style={styles.detailRow}>\n                        <Text variant=\"bodySmall\" style={screenStyles.date}>Units Consumed:</Text>\n                        <Text variant=\"bodyMedium\">\n                          {bill.units_consumed} {bill.tenancy_utility?.utility_type?.unit}\n                        </Text>\n                      </View>\n                    )}\n                  </View>\n                </View>\n              );\n            })\n          ) : (\n            <Text variant=\"bodyMedium\" style={screenStyles.empty}>No utility bills found</Text>\n          )}\n        </Card.Content>\n      </Card>\n    </ScrollView>\n  );\n}\n\nconst styles = StyleSheet.create({\n  summaryRow: {\n    flexDirection: 'row',\n    justifyContent: 'space-between',\n    paddingVertical: 4,\n  },\n  payButton: {\n    marginTop: 16,\n  },\n  filterContainer: {\n    flexDirection: 'row',\n    paddingHorizontal: 16,\n    marginBottom: 16,\n    gap: 8,\n  },\n  filterButton: {\n    flex: 1,\n  },\n  billItem: {\n    paddingVertical: 12,\n    borderBottomWidth: 1,\n    borderBottomColor: colors.border,\n  },\n  billHeader: {\n    flexDirection: 'row',\n    justifyContent: 'space-between',\n    alignItems: 'flex-start',\n    marginBottom: 8,\n  },\n  chip: {\n    height: 28,\n  },\n  billDetails: {\n    gap: 4,\n  },\n  detailRow: {\n    flexDirection: 'row',\n    justifyContent: 'space-between',\n  },\n});\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Admin\\Desktop\\SurveyCorps\\Projects\\estate-practice\\mobile\\src\\services\\BiometricService.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Admin\\Desktop\\SurveyCorps\\Projects\\estate-practice\\mobile\\src\\services\\SessionManager.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Use