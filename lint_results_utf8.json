hover:text-foreground mr-4\"\n              >\n                <ArrowLeft className=\"h-4 w-4 mr-2\" />\n                Landlords\n              </Link>\n              <h1 className=\"text-xl font-semibold\">Edit Landlord</h1>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div className=\"max-w-2xl mx-auto p-4 py-8\">\n        <form onSubmit={handleSubmit} className=\"space-y-6\">\n          {/* Basic Information */}\n          <Card>\n            <CardHeader>\n              <CardTitle>Basic Information</CardTitle>\n              <CardDescription>Update the landlord's basic account details</CardDescription>\n            </CardHeader>\n            <CardContent className=\"space-y-4\">\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                <div>\n                  <Label htmlFor=\"name\">Full Name *</Label>\n                  <Input\n                    id=\"name\"\n                    value={data.name}\n                    onChange={(e) => setData('name', e.target.value)}\n                    placeholder=\"John Doe\"\n                    required\n                  />\n                  {errors.name && (\n                    <p className=\"text-sm text-red-600 mt-1\">{errors.name}</p>\n                  )}\n                </div>\n\n                <div>\n                  <Label htmlFor=\"username\">Username *</Label>\n                  <Input\n                    id=\"username\"\n                    value={data.username}\n                    onChange={(e) => setData('username', e.target.value)}\n                    placeholder=\"johndoe\"\n                    required\n                  />\n                  {errors.username && (\n                    <p className=\"text-sm text-red-600 mt-1\">{errors.username}</p>\n                  )}\n                </div>\n              </div>\n\n              <div>\n                <Label htmlFor=\"email\">Email Address *</Label>\n                <Input\n                  id=\"email\"\n                  type=\"email\"\n                  value={data.email}\n                  onChange={(e) => setData('email', e.target.value)}\n                  placeholder=\"john@example.com\"\n                  required\n                />\n                {errors.email && (\n                  <p className=\"text-sm text-red-600 mt-1\">{errors.email}</p>\n                )}\n              </div>\n\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                <div>\n                  <Label htmlFor=\"password\">New Password</Label>\n                  <div className=\"relative\">\n                    <Input\n                      id=\"password\"\n                      type={showPassword ? 'text' : 'password'}\n                      value={data.password}\n                      onChange={(e) => setData('password', e.target.value)}\n                      placeholder=\"Leave blank to keep current password\"\n                    />\n                    <Button\n                      type=\"button\"\n                      variant=\"ghost\"\n                      size=\"sm\"\n                      className=\"absolute right-0 top-0 h-full px-3 py-2 hover:bg-transparent\"\n                      onClick={() => setShowPassword(!showPassword)}\n                    >\n                      {showPassword ? (\n                        <EyeOff className=\"h-4 w-4\" />\n                      ) : (\n                        <Eye className=\"h-4 w-4\" />\n                      )}\n                    </Button>\n                  </div>\n                  {errors.password && (\n                    <p className=\"text-sm text-red-600 mt-1\">{errors.password}</p>\n                  )}\n                </div>\n\n                <div>\n                  <Label htmlFor=\"password_confirmation\">Confirm New Password</Label>\n                  <div className=\"relative\">\n                    <Input\n                      id=\"password_confirmation\"\n                      type={showPasswordConfirmation ? 'text' : 'password'}\n                      value={data.password_confirmation}\n                      onChange={(e) => setData('password_confirmation', e.target.value)}\n                      placeholder=\"Confirm new password\"\n                    />\n                    <Button\n                      type=\"button\"\n                      variant=\"ghost\"\n                      size=\"sm\"\n                      className=\"absolute right-0 top-0 h-full px-3 py-2 hover:bg-transparent\"\n                      onClick={() => setShowPasswordConfirmation(!showPasswordConfirmation)}\n                    >\n                      {showPasswordConfirmation ? (\n                        <EyeOff className=\"h-4 w-4\" />\n                      ) : (\n                        <Eye className=\"h-4 w-4\" />\n                      )}\n                    </Button>\n                  </div>\n                  {errors.password_confirmation && (\n                    <p className=\"text-sm text-red-600 mt-1\">{errors.password_confirmation}</p>\n                  )}\n                </div>\n              </div>\n            </CardContent>\n          </Card>\n\n          {/* Account Status */}\n          <Card>\n            <CardHeader>\n              <CardTitle>Account Status</CardTitle>\n              <CardDescription>Current account status</CardDescription>\n            </CardHeader>\n            <CardContent>\n              <div className=\"flex items-center space-x-2\">\n                <div className={`h-3 w-3 rounded-full ${\n                  landlord.email_verified_at ? 'bg-green-500' : 'bg-gray-400'\n                }`} />\n                <span className=\"text-sm\">\n                  Account is {landlord.email_verified_at ? 'active' : 'inactive'}\n                </span>\n                {landlord.email_verified_at && (\n                  <span className=\"text-xs text-muted-foreground\">\n                    (verified on {new Date(landlord.email_verified_at).toLocaleDateString()})\n                  </span>\n                )}\n              </div>\n            </CardContent>\n          </Card>\n\n          {/* Form Actions */}\n          <div className=\"flex justify-end space-x-4\">\n            <Link href={route('admin.users.show', landlord.id)}>\n              <Button variant=\"outline\" type=\"button\">\n                Cancel\n              </Button>\n            </Link>\n            <Button type=\"submit\" disabled={processing}>\n              {processing ? 'Updating...' : 'Update Landlord'}\n            </Button>\n          </div>\n        </form>\n      </div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Admin\\Desktop\\SurveyCorps\\Projects\\estate-practice\\resources\\js\\pages\\admin\\users\\index.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'useForm' is defined but never used.","line":1,"column":24,"nodeType":"Identifier","messageId":"unusedVar","endLine":1,"endColumn":31,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"useForm"},"fix":{"range":[21,30],"text":""},"desc":"Remove unused variable \"useForm\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'Trash2' is defined but never used.","line":2,"column":58,"nodeType":"Identifier","messageId":"unusedVar","endLine":2,"endColumn":64,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Trash2"},"fix":{"range":[113,121],"text":""},"desc":"Remove unused variable \"Trash2\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'Mail' is defined but never used.","line":2,"column":91,"nodeType":"Identifier","messageId":"unusedVar","endLine":2,"endColumn":95,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Mail"},"fix":{"range":[146,152],"text":""},"desc":"Remove unused variable \"Mail\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,